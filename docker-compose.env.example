# Copie para .env.compose (ou outro nome) e use:
#   docker compose --env-file .env.compose up --build
#
# Não commite arquivos com segredos reais.

JWT_SECRET=sua_chave_jwt_forte_aqui

# Better Stack (Logs) — opcional; veja README ou docs do projeto
# BETTER_STACK_SOURCE_TOKEN=seu_source_token
# BETTER_STACK_SERVICE_NAME=estudemy-backend
# Região EU (se o painel indicar): BETTER_STACK_INGEST_URL=https://...
